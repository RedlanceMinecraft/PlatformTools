{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/build-libwebp\\.yml$"],
      "matchStrings": ["'(?<currentValue>v\\d+\\.\\d+\\.\\d+)'"],
      "depNameTemplate": "webmproject/libwebp",
      "datasourceTemplate": "github-tags"
    }
  ]
}
